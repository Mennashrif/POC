{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "Booking": "https://localhost:7003",
    "Billing": "https://localhost:7201",
    "Login": "https://localhost:7138"
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/esap",
    "Audience": "esap-gateway",
    "ClientId": "esap-gateway",
    "ClientSecret": "W46M4aeQWLlkIyTvAHZ7U0IzXCDE7fU3",
    "RedirectUri": "http://localhost:3000/callback",
    "TokenEndpointPath": "/protocol/openid-connect/token",
    "AuthEndpointPath": "/protocol/openid-connect/auth",
    "Scopes": "openid profile email"
  },
  "ReverseProxy": {
    "Routes": {
      "RoomManagement_Route": {
        "ClusterId": "RoomManagement_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/rooms/{**catch-all}"
        }
      },
      "RoomType_Route": {
        "ClusterId": "RoomManagement_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/roomtypes/{**catch-all}"
        }
      },
      "Billing_Route": {
        "ClusterId": "Billing_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/bills/{**catch-all}"
        }
      },
      "Booking_Route": {
        "ClusterId": "Booking_Cluster",
        //"AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/reservations/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "RoomManagement_Cluster": {
        "Destinations": {
          "roommanagement_destination": {
            "Address": "https://localhost:7062/"
          }
        }
      },
      "Billing_Cluster": {
        "Destinations": {
          "billing_destination": {
            "Address": "https://localhost:7201/"
          }
        }
      },
      "Booking_Cluster": {
        "Destinations": {
          "booking_destination": {
            "Address": "https://localhost:7003/"
          }
        }
      }
    }
  }
}
