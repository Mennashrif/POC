{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "Booking": "https://localhost:7003",
    "Billing": "https://localhost:7201"
  },
  "JwtSettings": {
    "SecretKey": "eSAP-POC-SuperSecret-Key-AtLeast32Chars!!",
    "Issuer": "eSAP-Login",
    "Audience": "eSAP-Services"
  },
  "ReverseProxy": {
    "Routes": {
      "Login_Route": {
        "ClusterId": "Login_Cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        }
      },
      "RoomManagement_Route": {
        "ClusterId": "RoomManagement_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/rooms/{**catch-all}"
        }
      },
      "RoomType_Route": {
        "ClusterId": "RoomManagement_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/roomtypes/{**catch-all}"
        }
      },
      "Billing_Route": {
        "ClusterId": "Billing_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/bills/{**catch-all}"
        }
      },
      "Booking_Route": {
        "ClusterId": "Booking_Cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/reservations/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "Login_Cluster": {
        "Destinations": {
          "login_destination": {
            "Address": "https://localhost:7138/"
          }
        }
      },
      "RoomManagement_Cluster": {
        "Destinations": {
          "roommanagement_destination": {
            "Address": "https://localhost:7062/"
          }
        }
      },
      "Billing_Cluster": {
        "Destinations": {
          "billing_destination": {
            "Address": "https://localhost:7201/"
          }
        }
      },
      "Booking_Cluster": {
        "Destinations": {
          "booking_destination": {
            "Address": "https://localhost:7003/"
          }
        }
      }
    }
  }
}
